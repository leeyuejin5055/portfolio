---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../lib/paths";

interface Props {
  project: CollectionEntry<"projects">;
  priority?: boolean;
}

const { project, priority = false } = Astro.props;
const { title, year, summary, cover, coverAlt } = project.data;
const href = `${import.meta.env.BASE_URL}work/${project.slug}`;
const coverSrc = withBase(cover);
---

<article class="project-item reveal">
  <a class="project-item__link" href={href}>
    <figure class="project-item__media">
      <img
        src={coverSrc}
        alt={coverAlt}
        loading={priority ? "eager" : "lazy"}
        width="1200"
        height="900"
      />
    </figure>
    <div class="project-item__meta">
      <h3 class="project-item__title">{title}</h3>
      <p class="project-item__year">{year}</p>
    </div>
    <p class="project-item__summary">{summary}</p>
  </a>
</article>

<style>
  .project-item__link {
    display: grid;
    gap: 0.85rem;
    text-decoration: none;
    color: inherit;
  }

  .project-item__media {
    margin: 0;
    overflow: hidden;
    background: #111;
    aspect-ratio: 3 / 4;
  }

  .project-item__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.7s var(--ease);
  }

  .project-item__link:hover .project-item__media img {
    transform: scale(1.03);
  }

  .project-item__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-item__title {
    font-size: 1.5rem;
  }

  .project-item__year {
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    color: var(--ink-muted);
  }

  .project-item__summary {
    font-size: 0.95rem;
    color: var(--ink-muted);
    max-width: 36ch;
  }

  @media (prefers-reduced-motion: reduce) {
    .project-item__media img {
      transition: none;
    }

    .project-item__link:hover .project-item__media img {
      transform: none;
    }
  }
</style>
