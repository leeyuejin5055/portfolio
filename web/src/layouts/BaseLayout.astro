---
import "../styles/global.css";
import { site } from "../data/site";
import { pathFromBase } from "../lib/paths";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = site.tagline } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : `${site.name} · ${site.role}`;
const path = pathFromBase(Astro.url.pathname);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header" data-header>
      <div class="container site-header__inner">
        <a class="brand" href={`${import.meta.env.BASE_URL}`}>{site.name}</a>
        <nav class="nav" aria-label="Primary">
          <a href={`${import.meta.env.BASE_URL}`} aria-current={path === "/" ? "page" : undefined}
            >Home</a
          >
          <a
            href={`${import.meta.env.BASE_URL}work`}
            aria-current={path.startsWith("/work") ? "page" : undefined}>Work</a
          >
          <a
            href={`${import.meta.env.BASE_URL}about`}
            aria-current={path === "/about" ? "page" : undefined}>About</a
          >
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__inner">
        <p>© {new Date().getFullYear()} {site.name}. Graphic design portfolio.</p>
        <p class="site-footer__contact">
          <a href={`mailto:${site.email}`}>{site.email}</a>
          <span aria-hidden="true"> · </span>
          <a href={`tel:${site.phone.replace(/-/g, "")}`}>{site.phone}</a>
        </p>
      </div>
    </footer>

    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <script>
      const header = document.querySelector("[data-header]");
      const onScroll = () => {
        header?.classList.toggle("is-scrolled", window.scrollY > 12);
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      const reveals = document.querySelectorAll(".reveal");
      if ("IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -5% 0px" },
        );
        reveals.forEach((el) => io.observe(el));
        // Reveal anything already in view immediately
        requestAnimationFrame(() => {
          reveals.forEach((el) => {
            const rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight && rect.bottom > 0) {
              el.classList.add("is-visible");
            }
          });
        });
      } else {
        reveals.forEach((el) => el.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
