---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";
import { site } from "../data/site";

const featured = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout>
  <section class="hero">
    <div class="hero__visual" aria-hidden="true">
      <div class="hero__grain"></div>
      <div class="hero__shape hero__shape--a"></div>
      <div class="hero__shape hero__shape--b"></div>
    </div>
    <div class="container hero__content">
      <p class="hero__role reveal">{site.role}</p>
      <h1 class="hero__brand reveal">{site.name}</h1>
      <p class="hero__tagline reveal">{site.tagline}</p>
      <div class="btn-group reveal">
        <a class="btn" href={`${import.meta.env.BASE_URL}work`}>View work</a>
        <a class="btn btn--ghost" href={`${import.meta.env.BASE_URL}about`}>About</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__head reveal">
        <h2 class="section__title">Selected work</h2>
        <a class="section__link" href={`${import.meta.env.BASE_URL}work`}>All projects</a>
      </div>
      <div class="work-grid">
        {featured.map((project, i) => <ProjectCard project={project} priority={i === 0} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - 4.5rem);
    display: grid;
    align-items: end;
    overflow: hidden;
    color: var(--surface);
    background: #15241c;
  }

  .hero__visual {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(160deg, rgba(21, 36, 28, 0.2), rgba(21, 36, 28, 0.75)),
      linear-gradient(45deg, #1f4d3a 0%, #2a3a32 45%, #0f1713 100%);
  }

  .hero__grain {
    position: absolute;
    inset: 0;
    opacity: 0.18;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: soft-light;
  }

  .hero__shape {
    position: absolute;
    border-radius: 50%;
    filter: blur(2px);
  }

  .hero__shape--a {
    width: min(55vw, 28rem);
    height: min(55vw, 28rem);
    right: -8%;
    top: 12%;
    background: radial-gradient(circle, #c8d9cf 0%, transparent 70%);
    opacity: 0.35;
    animation: drift 14s var(--ease) infinite alternate;
  }

  .hero__shape--b {
    width: min(40vw, 18rem);
    height: min(40vw, 18rem);
    left: 8%;
    bottom: 18%;
    background: radial-gradient(circle, #8fa894 0%, transparent 68%);
    opacity: 0.28;
    animation: drift 18s var(--ease) infinite alternate-reverse;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding-block: var(--space-2xl) var(--space-xl);
  }

  .hero__role {
    font-size: 0.8125rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--surface) 72%, transparent);
    margin-bottom: 0.75rem;
  }

  .hero__brand {
    font-size: clamp(3.5rem, 12vw, 7.5rem);
    line-height: 0.95;
    margin-bottom: 1rem;
  }

  .hero__tagline {
    max-width: 28ch;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    color: color-mix(in srgb, var(--surface) 82%, transparent);
    margin-bottom: 1.75rem;
  }

  .hero :global(.btn) {
    border-color: var(--surface);
    background: var(--surface);
    color: var(--ink);
  }

  .hero :global(.btn:hover) {
    background: transparent;
    color: var(--surface);
  }

  .hero :global(.btn--ghost) {
    background: transparent;
    color: var(--surface);
  }

  .hero :global(.btn--ghost:hover) {
    background: var(--surface);
    color: var(--ink);
  }

  .work-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-lg) var(--space-md);
  }

  @keyframes drift {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(-3%, 4%, 0) scale(1.06);
    }
  }

  @media (max-width: 768px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__shape--a,
    .hero__shape--b {
      animation: none;
    }
  }
</style>
